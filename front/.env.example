# ImageAuthenticator 배포 주소 (미설정 시 코드 기본값 사용)
# VITE_CONTRACT_ADDRESS=0x6154ab54f64106e00C715EBfC7cE6ce8C5dfF9CB

# 업로드 전 메타마스크를 이 체인으로 전환 (예: Sepolia 11155111, Hardhat 31337)
# VITE_CHAIN_ID=11155111

# 체인이 없을 때 추가 (wallet_switch 실패 코드 4902일 때만)
# VITE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# VITE_CHAIN_NAME=Sepolia

# 기본은 실제 온체인 registerImage / buyImage. 블록체인 없이만 개발할 때만:
# VITE_STUB_ONCHAIN=true

# 구매 시 컨트랙트에 buyImage(string pHash) payable 가 있어야 함 (등록 시 전달한 price와 동일 단위로 msg.value 전송).

